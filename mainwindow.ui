      <property name="styleSheet">
       <string notr="true">/* Mood page background */
QWidget#pageMood {
    background-color: #FFF0F3;
}


/* &quot;How are you feeling today?&quot; label */
QLabel#labelMoodQuestion {
    background-color: white;
    border: 1.5px solid #F7C5D5;
    border-radius: 14px;
    padding: 14px 20px;
    font-size: 15px;
    color: #C45C8A;
    font-weight: bold;
}

/* Emoji mood buttons - all 5 */
QPushButton#btnMoodLow,
QPushButton#btnMoodMeh,
QPushButton#btnMoodGood,
QPushButton#btnMoodGreat,
QPushButton#btnMoodAmazing {
    background-color: white;
    border: 1.5px solid #F7C5D5;
    border-radius: 16px;
    font-size: 28px;
    padding: 12px 8px;
    color: #4A4A4A;
    min-width: 80px;
    min-height: 90px;
}

QPushButton#btnMoodLow:hover,
QPushButton#btnMoodMeh:hover,
QPushButton#btnMoodGood:hover,
QPushButton#btnMoodGreat:hover,
QPushButton#btnMoodAmazing:hover {
    background-color: #FFE4EE;
    border: 1.5px solid #E8649A;
}

QPushButton#btnMoodLow:checked,
QPushButton#btnMoodMeh:checked,
QPushButton#btnMoodGood:checked,
QPushButton#btnMoodGreat:checked,
QPushButton#btnMoodAmazing:checked {
    background-color: #FFD6E7;
    border: 2.5px solid #E8649A;
}

/* Optional note input */
QLabel#labelMoodNoteTitle {
    font-size: 30px;
    font-weight: bold;
    color: #C45C8A;
    background: transparent;
}

QLineEdit#lineEditMoodNote {
    background-color: white;
    border: 1.5px solid #F7C5D5;
    border-radius: 12px;
    padding: 10px 16px;
    font-size: 13px;
    color: #4A4A4A;
    min-height: 40px;
}

QLineEdit#lineEditMoodNote:focus {
    border: 1.5px solid #E8649A;
}

/* Status label */
QLabel#labelMoodStatus {
    font-size: 15px;
    background: transparent;
    font-style: italic;
}

/* Save mood button */
QPushButton#btnSaveMood {
    background-color: #E8649A;
    color: white;
    border: none;
    border-radius: 14px;
    padding: 12px 30px;
    font-size: 14px;
    font-weight: bold;
    min-height: 10
px;
}

QPushButton#btnSaveMood:hover {
    background-color: #D4507E;
}

QPushButton#btnSaveMood:pressed {
    background-color: #C03060;
}



QPushButton#btnBackFromMood:hover {
    background-color: #FFE4EE;
}</string>
