        <property name="styleSheet">
         <string notr="true">QListWidget#listWidgetHistory
{
    background: #FFF9FB;
    border: 2px solid #F7C7D7;
    border-radius: 22px;

    padding: 12px;
    outline: none;

    font-family: &quot;Poppins&quot;;
    font-size: 11pt;
    color: #7A5A68;
}
QListWidget#listWidgetHistory::item
{
    background: #FFFFFF;

    border: 2px solid #F9D8E4;
    border-radius: 18px;

    margin: 8px;
    padding: 16px;

    min-height: 60px;
}
QListWidget#listWidgetHistory::item:hover
{
    background: #FFF1F6;
    border: 2px solid #F6AFC7;
}
QListWidget#listWidgetHistory::item:selected
{
    background: #FFE4EF;
    border: 2px solid #EC7CA6;

    color: #B34873;
}
QScrollBar:vertical
{
    background: transparent;
    width: 14px;
    border: none;
}

QScrollBar::handle:vertical
{
    background: #F4B5CA;
    border-radius: 7px;
    min-height: 45px;
}

QScrollBar::handle:vertical:hover
{
    background: #EB90B2;
}

QScrollBar::add-line:vertical,
QScrollBar::sub-line:vertical
{
    height:0px;
}

QScrollBar::add-page:vertical,
QScrollBar::sub-page:vertical
{
    background: transparent;
}</string>
