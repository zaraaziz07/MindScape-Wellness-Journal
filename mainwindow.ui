   <string notr="true">QMainWindow {
    background-color: #FFF0F3;
}
QWidget {
    background-color: transparent;
}
QWidget#centralwidget {
    background-color: #FFF0F3;
}
QWidget#pageHome {
    background-color: #FFF0F3;
}
QLabel {
    background-color: transparent;
}
QPushButton#btnJournal,
QPushButton#btnMood,
QPushButton#btnQuote,
QPushButton#btnHabits,
QPushButton#btnBooks,
QPushButton#btnHistory {
    background-color: #FFFFFF;
    border: 1.5px solid #F7C5D5;
    border-radius: 18px;
    font-size: 26px;
    font-weight: bold;
    color: #C45C8A;
}
QPushButton#btnJournal:hover,
QPushButton#btnMood:hover,
QPushButton#btnQuote:hover,
QPushButton#btnHabits:hover,
QPushButton#btnBooks:hover,
QPushButton#btnHistory:hover {
    background-color: #FFE4EE;
    border-color: #E8649A;
}
QLabel#labelAppName {
    font-size: 55px;
    font-weight: bold;
    color: #E8649A;
}
QLabel#labelGreeting {
    font-size: 18px;
    color: #B07090;
}
QLabel#labelStreak {
    font-size: 14px;
    color: #E8649A;
    background-color: #FFE4EE;
    border-radius: 12px;
    padding: 8px 16px;
    border: 1px solid #F7C5D5;
}
QFrame#streakFrame {
    background-color: #FFE4EE;
    border: 1.5px solid #F7C5D5;
    border-radius: 16px;
    padding: 10px;
}

QLabel#labelStreakNumber {
    font-size: 22px;
    font-weight: bold;
    color: #E8649A;
    background: transparent;
}

QLabel#labelStreakSub {
    font-size: 11px;
    color: #B07090;
    background: transparent;
}

QLabel#labelDayMon, QLabel#labelDayTue, QLabel#labelDayWed,
QLabel#labelDayThu, QLabel#labelDayFri, QLabel#labelDaySat,
QLabel#labelDaySun {
    font-size: 11px;
    font-weight: bold;
    color: #C45C8A;
    background: transparent;
    min-width: 24px;
}
QLabel#myJournal
{
 font-size: 40px;
