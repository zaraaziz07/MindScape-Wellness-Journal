  <property name="styleSheet">
   <string notr="true">/* Habit page background */
QWidget#pageHabits {
    background-color: #FFF0F3;
}

QScrollArea#scrollAreaHabits {
    background: transparent;
    border: none;
}

QScrollArea#scrollAreaHabits &gt; QWidget &gt; QWidget {
    background: transparent;
}

/* Line edit for new habit */
QLineEdit#lineEditNewHabit {
    background: white;
    border: 1.5px solid #F7C5D5;
    border-radius: 12px;
    padding: 8px 14px;
    font-size: 13px;
    color: #C45C8A;
}

QLineEdit#lineEditNewHabit::placeholder {
    color: #D4A0B8;
}

/* Add habit button */
QPushButton#btnAddHabitlist {
    background-color: #E8649A;
    color: white;
    border: none;
    border-radius: 12px;
    padding: 8px 18px;
    font-size: 13px;
    font-weight: bold;
}

QPushButton#btnAddHabitlist:hover {
    background-color: #D4507E;
}

/* Progress label */
QLabel#labelHabitProgress {
    background-color: #FFE4EE;
    border: 1px solid #F7C5D5;
    border-radius: 10px;
    padding: 6px 14px;
    font-size: 13px;
    color: #E8649A;
    font-weight: bold;
}

/* Habits page title */
QLabel#labelHabitsTitle {
    font-size: 22px;
    font-weight: bold;
    color: #E8649A;
    background: transparent;
}</string>
